prox() {
    PM3_DIR="$HOME/proxmark3"

    if [ "$1" = "tcp" ]; then
        host=${2:-localhost}
        pm3 tcp:$host:5000

    elif [ "$1" = "usb" ]; then
        pm3 /dev/ttyACM0

    elif [ "$1" = "update" ]; then
        echo "[=] Updating Proxmark3..."

        if [ ! -d "$PM3_DIR" ]; then
            echo "[!] Repo not found, cloning..."
            git clone https://github.com/RfidResearchGroup/proxmark3 "$PM3_DIR" || return
        fi

        cd "$PM3_DIR" || return

        echo "[=] Pulling latest changes..."
        git pull || return

        echo "[=] Installing all dependencies..."
        sudo apt update
        sudo apt install -y \
            build-essential \
            git \
            libusb-1.0-0-dev \
            pkg-config \
            liblz4-dev \
            libbz2-dev \
            zlib1g-dev \
            libncurses5-dev \
            libreadline-dev \
            libssl-dev

        echo "[=] Building PM3 client..."
        make clean
        make all || { echo "[!] Build failed"; return; }

        echo "[=] Installing client..."
        if [ -f "client/proxmark3" ]; then
            sudo cp client/proxmark3 /usr/local/bin/pm3
            sudo chmod +x /usr/local/bin/pm3
            echo "[+] pm3 updated and installed!"
        else
            echo "[!] Build failed: client/proxmark3 not found"
        fi

    elif [ "$1" = "flash" ]; then
        echo "[=] Flashing Proxmark3 firmware..."

        if [ ! -d "$PM3_DIR" ]; then
            echo "[!] Repo not found, cloning..."
            git clone https://github.com/RfidResearchGroup/proxmark3 "$PM3_DIR" || return
        fi

        cd "$PM3_DIR" || return

        echo "[=] Pulling latest changes..."
        git pull || return

        echo "[=] Building firmware..."
        make clean
        make PLATFORM=PM3GENERIC || { echo "[!] Build failed"; return; }

        echo "[=] Flashing bootrom..."
        ./pm3-flash-bootrom || { echo "[!] Bootrom flash failed"; return; }

        echo "[=] Flashing fullimage..."
        ./pm3-flash-fullimage || { echo "[!] Fullimage flash failed"; return; }

        echo "[+] Flash complete!"

    else
        echo "Usage:"
        echo "  prox tcp [host]"
        echo "  prox usb"
        echo "  prox update"
        echo "  prox flash"
    fi
}
