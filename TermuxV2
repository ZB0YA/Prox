prox() {
    DUMP_DIR="/storage/emulated/0/NFC_RFID_dump"

    if [ "$1" = "tcp" ]; then
        host=${2:-localhost}
        cd "$DUMP_DIR" || return
        sleep 5
        pm3 tcp:$host:5000

    elif [ "$1" = "update" ]; then
        PM3_DIR="$HOME/proxmark3"

        echo "[=] Updating Proxmark3..."

        if [ ! -d "$PM3_DIR" ]; then
            echo "[!] Repo not found, cloning..."
            git clone https://github.com/RfidResearchGroup/proxmark3.git "$PM3_DIR"
        fi

        cd "$PM3_DIR" || return

        echo "[=] Pulling latest changes..."
        git pull || return

        echo "[=] Building..."
        make clean && make host || return

        echo "[=] Installing..."

        if [ -f "client/proxmark3" ]; then
            ln -sf "$PM3_DIR/client/proxmark3" $PREFIX/bin/pm3
            chmod +x $PREFIX/bin/pm3
            echo "[+] Done! pm3 updated."
        else
            echo "[!] Build failed!"
        fi

    elif [ "$1" = "eml" ]; then
        eml_file="$2"
        host=${3:-localhost}

        if [ -z "$eml_file" ]; then
            echo "[!] Usage: prox eml <file.eml> [host]"
            return
        fi

        # --- STEP 1: exactly like prox tcp ---
        cd "$DUMP_DIR" || return
        sleep 5
        echo "[=] Connecting to PM3 via TCP: $host"

        # --- STEP 2: locate the file ---
        if [ -f "$eml_file" ]; then
            full_path="$eml_file"
        elif [ -f "$DUMP_DIR/$eml_file" ]; then
            full_path="$DUMP_DIR/$eml_file"
        else
            echo "[!] File not found:"
            echo "    $eml_file"
            echo "    $DUMP_DIR/$eml_file"
            return
        fi

        echo "[=] Using file: $full_path"

        # --- STEP 3: extract UID (first 4 bytes) ---
        uid=$(head -n1 "$full_path" | tr -d ' \n\r' | cut -c1-8 | tr '[:lower:]' '[:upper:]')

        echo "[+] Extracted UID: $uid"
        echo "[=] Starting emulation over TCP..."

        # --- STEP 4: run emulation ---
        pm3 tcp:$host:5000 -c "hf mf sim --1k -u $uid"
        echo "[+] Emulation started"

    else
        echo "Usage:"
        echo "  prox tcp [host]"
        echo "  prox update"
        echo "  prox eml <file.eml> [host]"
    fi
}
